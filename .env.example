# VPASTOCK Backend Configuration
# Copy file này thành .env và điền giá trị, KHÔNG commit vào git

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

DATABASE_URL=sqlite+aiosqlite:///./vpastock.db
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_REALTIME=60
CACHE_TTL_CLOSED=3600
CACHE_TTL_FINANCIAL=86400

# Lấy token từ F12 → Network khi login fireant.vn (chỉ điền trên máy bạn)
FIREANT_TOKEN=

# Lấy key từ console.anthropic.com (chỉ điền trên máy bạn)
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=1024
AI_CACHE_MINUTES=30

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://vpastock.com
LOG_LEVEL=INFO
LOG_FILE=logs/vpastock.log
